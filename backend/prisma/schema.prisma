
// Prisma schema for AngiSoft backend (Postgres)

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum ProfileVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}

model Employee {
  id                  String   @id @default(uuid())
  firstName           String
  lastName            String
  email               String   @unique
  phone               String?
  role                Role     @default(DEVELOPER)
  username            String?  @unique
  passwordHash        String?
  invitedAt           DateTime?
  inviteToken         String?  @unique
  inviteExpiry        DateTime?
  resetToken          String?  @unique
  resetExpiry         DateTime?
  twoFactorSecret     String?
  twoFactorEnabled    Boolean  @default(false)
  acceptedAt          DateTime?
  bio                 String?
  avatarUrl           String?
  publicTitle         String?
  publicSummary       String?
  location            String?
  websiteUrl          String?
  linkedinUrl         String?
  twitterUrl          String?
  githubUrl           String?
  skills              String[] @default([])
  specialties         String[] @default([])
  publicEmail         String?
  publicPhone         String?
  profilePublished    Boolean  @default(true)
  profileVisibility   ProfileVisibility @default(PUBLIC)
  department          String?
  seniorityLevel      String?         // Junior, Mid, Senior, Lead, Principal
  joinYear            Int?
  featured            Boolean  @default(false)
  profileOrder        Int      @default(0)
  cvUrl               String?   // Resume / CV file
  portfolioUrl        String?
  experienceJson      Json?     // Array of { title, company, startDate, endDate, description }
  educationJson       Json?     // Array of { institution, degree, year }
  resumePublished     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  posts               BlogPost[]
  services            Service[]
  projectsAuthored    Project[]   @relation("authoredProjects")
  bookingsAssigned    Booking[]   @relation("assignedTo")
  clientProjectsOwned ClientProject[] @relation("clientProjectOwner")
  projectActivities   ProjectActivity[]
  projectComments     ProjectComment[]
  refreshTokens       RefreshToken[]
  backupCodes         TwoFactorBackupCode[]
  staffBlogs          StaffBlog[]
  certifications      Certification[]
  projectContributions ProjectEmployee[]
  roleAssignments     EmployeeRoleAssignment[]
  portfolioItems      EmployeePortfolioItem[]
  profileStats        EmployeeProfileStat[]

  // ─── Admin/Staff Portal reconstruction (Phase 0) ───
  departmentId        String?   // relation "EmployeeDepartment" (Department), onDelete SetNull
  departmentRef       Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  positionId          String?   // relation "EmployeePosition" (Position), onDelete SetNull
  positionRef         Position?  @relation("EmployeePosition", fields: [positionId], references: [id], onDelete: SetNull)
  employeePermissions EmployeePermission[]
  productTeamMembers  ProductTeamMember[]
  assignedEnquiries   ContactEnquiry[] @relation("ContactEnquiryAssignee")

  @@index([departmentId])
  @@index([positionId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  MARKETING
  DEVELOPER
  HR
  STAFF
  CONTENT_CREATOR
  BLOG_MANAGER
}

model AppRole {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignments EmployeeRoleAssignment[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         AppRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model EmployeeRoleAssignment {
  id         String   @id @default(uuid())
  employeeId String
  roleId     String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       AppRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([employeeId, roleId])
  @@index([employeeId])
  @@index([roleId])
}

model EmployeePortfolioItem {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  slug        String?
  category    String?
  summary     String
  description String?
  imageUrl    String?
  projectUrl  String?
  repoUrl     String?
  techStack   String[] @default([])
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId, published])
}

model EmployeeProfileStat {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  label       String
  value       Int
  suffix      String   @default("")
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId, published])
}

model Client {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  org           String?
  passwordHash  String?
  avatarUrl     String?
  location      String?
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  clientProjects ClientProject[]
  accessTokens  ClientAccessToken[]
  supportTickets SupportTicket[]
  inquiries     ProductInquiry[]
}

model Booking {
  id              String       @id @default(uuid())
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title           String
  description     String
  projectType     ProjectType
  details         Json?
  status          BookingStatus @default(SUBMITTED)
  priceEstimate   Float?
  assignedToId    String?
  assignedTo      Employee?    @relation("assignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  termsAcceptedAt DateTime?
  depositPaidAt   DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  files           File[]
  payments        Payment[]
  notes           Note[]
  clientProject   ClientProject?
  events          BookingEvent[]

  // --- Workflow / progress extension (additive; BookingStatus enum unchanged) ---
  publicReference String   @unique
  currentStage    String   @default("submitted")
  trackingToken   String   @unique

  // Origin / source metadata (validated against an allow-list in the backend).
  source          String?  // direct|services-list|service-detail|pricing|product-detail|contact|custom-cta|repeat-booking
  sourcePath      String?  // full referrer URL for source analytics
  referrerEntityType String? // service|package|product
  referrerEntityId String?

  // Canonical entity linkage (verified against backend by slug; Product has no FK today).
  requestEntityType String? // service|product
  requestEntityId   String?
  requestEntitySlug String?
  serviceSlug       String?
  serviceTitle      String?
  packageSlug       String?
  packageTitle      String?
  productSlug       String?
  productTitle      String?

  requestType      String?  // maps to ProjectType or a custom value
  desiredOutcome   String?
  preferredTimeline String?
  preferredDate    DateTime?
  budgetAmount     Float?
  currency         String   @default("KES")

  quotedAmount     Float?
  quotedCurrency   String?
  pricingType      String?  // fixed|hourly|quote

  submittedAt      DateTime?
  contactEnquiries ContactEnquiry[] @relation("BookingContactEnquiries")
}

enum ProjectType {
  SOFTWARE
  DATA_ANALYSIS
  CYBER_SERVICE
  ADVERTISING
  INTERNET_SERVICE
  ENTERTAINMENT
  RESUME
  DOCUMENT_EDIT
  REPORT
  OTHER
}

enum BookingStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  TERMS_ACCEPTED
  DEPOSIT_PAID
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

// Workflow event history. `type` values are defined in the backend
// (BOOKING_EVENT_TYPES) rather than a Prisma enum so the catalog can grow
// without a migration. Visibility controls customer-facing exposure.
model BookingEvent {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type        String // booking_submitted|stage_changed|information_requested|customer_replied|file_uploaded|quotation_created|quotation_sent|quotation_accepted|quotation_rejected|payment_requested|payment_received|work_started|progress_updated|customer_review_requested|changes_requested|booking_completed|booking_cancelled
  title       String
  description String?
  stage       String?   // machine stage value at event time
  status      BookingStatus?
  visibility  String   @default("customer") // customer|staff|internal
  actorType   String   @default("system") // client|staff|system
  actorId     String?
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([bookingId])
  @@index([bookingId, createdAt])
}

model Payment {
  id              String      @id @default(uuid())
  bookingId       String?
  booking         Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientId        String?
  amount          Float
  currency        String      @default("KES")
  provider        PaymentProvider
  providerId      String      @unique
  status          PaymentStatus
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MPESA
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Service {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  description      String
  category         String   @default("General")  // Legacy label; prefer categoryId when available
  categoryId       String?
  categoryRef      ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  priceFrom        Float?
  currency         String   @default("KES")
  pricing          Json?     // Pricing tiers/packages (object or array). Phase 5 admin pricing endpoint.
  targetAudience   String?  // Comma-separated or JSON; e.g., "Startups, Businesses, Enterprises"
  scope            String?  // Project duration/scope; e.g., "2-12 weeks"
  features         String[] @default([])
  images           String[]
  seoTitle         String?
  seoDesc          String?
  authorId         String?
  author           Employee? @relation(fields: [authorId], references: [id])
  published        Boolean   @default(false)
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  contactEnquiries ContactEnquiry[] @relation("ServiceContactEnquiries")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  services    Service[]
}

model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  type        String
  images      String[]
  demoUrl     String?
  repoUrl     String?
  techStack   String[]
  industry    String?
  featured    Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?
  authorId    String?
  author      Employee? @relation("authoredProjects", fields: [authorId], references: [id], onDelete: SetNull)
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employees   ProjectEmployee[]
  projectActivities ProjectActivity[] @relation("portfolioProjectActivities")
}

model ClientProject {
  id           String              @id @default(uuid())
  bookingId    String              @unique
  booking      Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  description  String
  status       ClientProjectStatus @default(PLANNING)
  progress     Int                 @default(0)
  ownerId      String?
  owner        Employee?           @relation("clientProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  startedAt    DateTime?
  dueAt        DateTime?
  deliveredAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  milestones   ProjectMilestone[]
  activities   ProjectActivity[] @relation("clientProjectActivities")
  comments     ProjectComment[]
  deliverables ProjectDeliverable[]
  files        File[]

  @@index([clientId])
  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
}

enum ClientProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  DELIVERED
  COMPLETED
  CANCELLED
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String
  project     ClientProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      MilestoneStatus @default(TODO)
  sortOrder   Int             @default(0)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@index([status])
}

enum MilestoneStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
}

model ProjectActivity {
  id              String              @id @default(uuid())

  // Optional ClientProject linkage (was previously required). Made optional to
  // allow activities bound to the public portfolio `Project` model instead.
  clientProjectId String?
  clientProject   ClientProject?      @relation("clientProjectActivities", fields: [clientProjectId], references: [id], onDelete: SetNull)

  // Optional public portfolio Project linkage (FK-free at DB level was previously
  // the only target; now reconciled via this explicit optional relation).
  portfolioProjectId String?
  portfolioProject   Project?         @relation("portfolioProjectActivities", fields: [portfolioProjectId], references: [id], onDelete: SetNull)

  actorId         String?
  actor           Employee?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  type            ProjectActivityType
  message         String
  meta            Json?
  visibleToClient Boolean             @default(true)
  createdAt       DateTime            @default(now())

  @@index([clientProjectId])
  @@index([portfolioProjectId])
  @@index([createdAt])
}

enum ProjectActivityType {
  PROJECT_CREATED
  STATUS_CHANGED
  PROGRESS_UPDATED
  MILESTONE_CREATED
  MILESTONE_UPDATED
  COMMENT_ADDED
  FILE_UPLOADED
  DELIVERABLE_ADDED
  DELIVERABLE_ACCEPTED
}

model ProjectComment {
  id         String                   @id @default(uuid())
  projectId  String
  project    ClientProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String?
  author     Employee?                @relation(fields: [authorId], references: [id], onDelete: SetNull)
  clientId   String?
  body       String
  visibility ProjectCommentVisibility @default(CLIENT)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  files      File[]

  @@index([projectId])
  @@index([visibility])
}

enum ProjectCommentVisibility {
  INTERNAL
  CLIENT
}

model ProjectDeliverable {
  id          String            @id @default(uuid())
  projectId   String
  project     ClientProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      DeliverableStatus @default(DRAFT)
  sharedAt    DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  files       File[]

  @@index([projectId])
  @@index([status])
}

enum DeliverableStatus {
  DRAFT
  SHARED
  ACCEPTED
  REVISION_REQUESTED
}

model ClientAccessToken {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  purpose   String   @default("portal")
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([expiresAt])
}
model BlogPost {
  id             String        @id @default(uuid())
  title          String
  slug           String        @unique
  subtitle       String?
  content        String
  contentType    String        @default("article")
  mediaUrl       String?
  transcript     String?
  coverImage     String?
  excerpt        String?
  readingTime    Int?
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]      @default([])
  featured       Boolean       @default(false)
  views          Int           @default(0)
  likes          Int           @default(0)
  categoryId     String?
  category       BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId       String
  author         Employee      @relation(fields: [authorId], references: [id])
  tags           String[]
  published      Boolean       @default(false)
  publishedAt    DateTime?
  visibilityType String        @default("permanent")
  visibleUntil   DateTime?
  resourceLinks  Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  comments       BlogComment[]
  reactions      BlogReaction[]
}

model File {
  id         String   @id @default(uuid())
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ownerType  String
  ownerId    String?
  filename   String
  url        String
  mime       String
  size       Int
  uploadedBy String?
  metadata   Json?
  clientProjectId String?
  clientProject   ClientProject? @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
  deliverableId   String?
  deliverable     ProjectDeliverable? @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  commentId       String?
  comment         ProjectComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AboutSection {
  id        String   @id @default(uuid())
  key       String   @unique // stable identifier used by useAboutPage buildAboutFromSections. 26 canonical keys: heroSlides, intro, numbersHeading, numberStories, geography, sustainability, collaboration, timelineHeading, timeline, industriesHeading, industries, clientsHeading, clients, clientStats, clientHighlights, testimonialsHeading, serviceMap, transparency, partnerships, solutionTypes, technologies, specializedCapabilities, whyGuarantee, pricing, pricingQuotation, cta
  title     String // human label for the admin CMS
  enabled   Boolean  @default(true) // drives the frontend's `enabled !== false` filter
  sortOrder Int      @default(0) // drives the page composer ordering
  content   Json? // section-specific payload (rich shape per key)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([enabled])
}

model Testimonial {
  id              String   @id @default(uuid())
  name            String
  company         String?
  role            String?
  text            String
  rating          Int?
  imageUrl        String?
  videoUrl        String?
  location        String?
  projectType     String?
  productId       String?
  confirmed       Boolean  @default(false)
  featured        Boolean  @default(false)
  rejected        Boolean  @default(false)
  rejectionReason String?
  adminReply      String?
  helpfulCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  reactions       ReviewReaction[]
}

model ReviewReaction {
  id            String      @id @default(uuid())
  testimonialId String
  testimonial   Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)
  visitorKey    String
  type          String      @default("helpful")
  createdAt     DateTime    @default(now())
  @@unique([testimonialId, visitorKey])
}

model Note {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorId  String?
  text      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  userType  String   @default("employee")
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  meta      Json?
  createdAt DateTime @default(now())
  @@index([userId, read])
  @@index([createdAt])
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  body        String
  audience    String   @default("all")
  priority    String   @default("normal")
  published   Boolean  @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Newsletter {
  id             String   @id @default(uuid())
  subject        String
  body           String
  htmlBody       String?
  status         String   @default("draft")
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int      @default(0)
  openCount      Int      @default(0)
  clickCount     Int      @default(0)
  authorId       String?
  createdAt      DateTime @default(now())
}

model Survey {
  id          String   @id @default(uuid())
  title       String
  description String?
  audience    String   @default("clients")
  status      String   @default("draft")
  questions   Json
  publishedAt DateTime?
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  responses   SurveyResponse[]
}

model SurveyResponse {
  id           String   @id @default(uuid())
  surveyId     String
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  respondentId String?
  answers      Json
  createdAt    DateTime @default(now())
  @@index([surveyId])
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  posts       BlogPost[]
}

model BlogComment {
  id        String   @id @default(uuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String?
  parentId  String?
  name      String?
  email     String?
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([postId])
}

model BlogReaction {
  id         String   @id @default(uuid())
  postId     String
  post       BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorKey String
  type       String   @default("like")
  createdAt  DateTime @default(now())
  @@unique([postId, visitorKey])
}

model Lead {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String?
  source       String?
  status       String   @default("new")
  notes        String?
  assignedToId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactEnquiry {
  id          String   @id @default(uuid())
  publicReference String @unique

  name    String
  email   String
  phone   String?
  preferredResponseMethod String @default("email") // email | phone | whatsapp

  enquiryType String // service | product | pricing | support | partnership | careers | general
  subject     String
  message     String

  serviceId   String?
  service     Service? @relation("ServiceContactEnquiries", fields: [serviceId], references: [id])
  productId   String?
  product     Product? @relation("ProductContactEnquiries", fields: [productId], references: [id])
  bookingId   String?
  booking     Booking? @relation("BookingContactEnquiries", fields: [bookingId], references: [id])
  bookingReference String?
  organisation String?

  source    String?
  sourcePath String?

  status    String   @default("new") // new | acknowledged | in_review | awaiting_customer | responded | converted_to_booking | closed | spam
  priority  String   @default("normal")
  assignedStaffId String?

  // ─── Admin/Staff Portal reconstruction (Phase 0) ───
  assigneeId String? // relation "ContactEnquiryAssignee" (Employee), onDelete SetNull
  assignee   Employee? @relation("ContactEnquiryAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  respondedAt DateTime?
  closedAt DateTime?

  @@index([enquiryType])
  @@index([status])
  @@index([bookingReference])
  @@index([assigneeId])
}

model SupportTicket {
  id           String   @id @default(uuid())
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  subject      String
  body         String
  status       String   @default("open")
  priority     String   @default("normal")
  assignedToId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  messages     TicketMessage[]
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String
  internal  Boolean       @default(false)
  createdAt DateTime      @default(now())
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  tagline     String?
  description String
  category    String?
  logoUrl     String?
  bannerUrl   String?
  features    Json?
  pricing     Json?
  screenshots Json?
  demoUrl     String?
  status      ProductStatus @default(DEVELOPMENT)
  seoTitle    String?
  seoDesc     String?
  published   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inquiries   ProductInquiry[]
  faqs        ProductFaq[]
  contactEnquiries ContactEnquiry[] @relation("ProductContactEnquiries")
  productTeamMembers ProductTeamMember[]
}

enum ProductStatus {
  PLANNED
  DEVELOPMENT
  BETA
  LIVE
  MAINTENANCE
  DEPRECATED
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  sessionId String?
  createdAt DateTime @default(now())
  @@index([path, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  type      String
  entity    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
  @@index([type, createdAt])
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  ip         String?
  userAgent  String?
  fingerprint String?
  revoked    Boolean  @default(false)
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actorRole Role?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())
}

model TwoFactorBackupCode {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  codeHash   String
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ─── Newsletter Subscribers ─────────────────────────────────────────
model Subscriber {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  confirmed     Boolean  @default(false)
  confirmToken  String?  @unique
  unsubToken    String   @unique @default(uuid())
  subscribedAt  DateTime @default(now())
  confirmedAt   DateTime?
  unsubscribedAt DateTime?
  preferences   SubscriberPreference[]
}

// ─── FAQ (fetched by ChatWidget and FAQ page) ───────────────────────
model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// ─── ChatBot Conversations ────────────────────────────────────────
model ChatConversation {
  id              String   @id @default(uuid())
  visitorName     String
  visitorEmail    String
  visitorPhone    String?
  deviceFingerprint String?
  intent          String?  // "booking", "inquiry", "support", etc.
  messages        ChatMessage[]
  quality         Int?     // 1-5 rating for conversation quality
  notes           String?
  status          String   @default("open") // open, closed, converted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visitorEmail])
  @@index([deviceFingerprint])
  @@index([status])
  @@index([createdAt])
}

model ChatMessage {
  id              String   @id @default(uuid())
  conversationId  String
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          String   @default("visitor") // "visitor" or "bot"
  message         String
  tokens          Int?     // Token count for API usage tracking
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ─── Staff Certifications ──────────────────────────────────────────
model Certification {
  id        String   @id @default(uuid())
  employeeId String
  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name      String
  issuer    String
  year      Int?
  url       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([employeeId])
}

// ─── Staff Blogs (personal blogs / portfolio posts) ─────────────────
model StaffBlog {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title      String
  slug       String   @unique
  content    String
  coverImage String?
  tags       String[] @default([])
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([employeeId])
}

// ─── Job Postings / Careers ────────────────────────────────────────
enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  FILLED
  ON_HOLD
  ARCHIVED
}

enum SalaryVisibility {
  HIDDEN
  RANGE
  EXACT
}

model JobPosting {
  id                   String          @id @default(uuid())
  title                String
  slug                 String          @unique
  status               JobStatus       @default(DRAFT)
  department           String?
  location             String          @default("Nairobi, Kenya")
  employmentType       String?         // Full-Time, Part-Time, Contract, Internship
  workplaceType        String?         // Remote, On-Site, Hybrid
  experienceLevel      String?         // Entry, Mid, Senior, Lead
  summary              String?
  description          String
  responsibilities      String[]        @default([])
  requirements         String[]
  preferredQualifications String[]     @default([])
  technologies         String[]        @default([])
  salaryMin            Int?
  salaryMax            Int?
  salaryCurrency       String          @default("KES")
  salaryVisibility     SalaryVisibility @default(RANGE)
  openings             Int?            @default(1)
  featured             Boolean         @default(false)
  applicationDeadline  DateTime?
  publishedAt          DateTime?
  // legacy (kept for admin CMS compat)
  type                 String          @default("full-time") // full-time, part-time, contract, internship
  benefits             String[]
  salaryRange          String?
  published            Boolean         @default(false)
  expiresAt            DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([status])
  @@index([department])
  @@index([featured])
}

// ─── Company Stats (key facts section) ─────────────────────────────
model CompanyStat {
  id        String   @id @default(uuid())
  label     String
  value     Int
  suffix      String   @default("")
  // Semantic formatting type consumed by the frontend formatter.
  valueType String   @default("plain")
  prefix    String   @default("")
  useGrouping Boolean? @map("use_grouping")
  icon        String?
  description String?
  order       Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Homepage Sections (dynamic section ordering) ──────────────────
model HomePageSection {
  id        String   @id @default(uuid())
  sectionId   String   @unique
  title       String
  component   String?
  description String?
  visible     Boolean  @default(true)
  order     Int      @default(0)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Product Inquiries ─────────────────────────────────────────────
model ProductInquiry {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new") // new, contacted, qualified, closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([productId])
  @@index([status])
}

// ─── Product FAQs ──────────────────────────────────────────────────
model ProductFaq {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([productId])
}

// ─── Project Employee Contributions ────────────────────────────────
model ProjectEmployee {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       String?  // "lead", "developer", "designer", etc.
  createdAt  DateTime @default(now())
  @@unique([projectId, employeeId])
}

// ─── Subscriber Tags / Preferences ─────────────────────────────────
model SubscriberPreference {
  id           String   @id @default(uuid())
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  tag          String
  createdAt    DateTime @default(now())
  @@unique([subscriberId, tag])
}

// ──────────────────────────────────────────────────────────────────────
// ─── Admin/Staff Portal reconstruction (Phase 0) ──────────────────────
// ──────────────────────────────────────────────────────────────────────

// Organizational departments (engineering, design, marketing, etc.)
model Department {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions          Position[]
  employees          Employee[] @relation("EmployeeDepartment")
}

// A role/title within a department, with default permission + seniority keys.
model Position {
  id                      String   @id @default(uuid())
  departmentId            String
  department              Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  title                   String
  displayTitleTemplate    String?
  defaultPermissionKeys   String[] @default([])
  seniorityLevels         String[] @default([])
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  employees Employee[] @relation("EmployeePosition")

  @@unique([departmentId, title])
  @@index([departmentId])
}

// Per-employee explicit permission grants / denials (overrides role presets).
model EmployeePermission {
  id            String   @id @default(uuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  permissionKey String
  effect        String   // "GRANT" | "DENY"
  grantedById   String?
  grantedAt     DateTime @default(now())
  expiresAt     DateTime?

  @@unique([employeeId, permissionKey])
  @@index([employeeId])
  @@index([permissionKey])
}

// Reusable bundles of permission keys that can be assigned to a position/employee.
model PermissionPreset {
  id             String   @id @default(uuid())
  key            String   @unique
  name           String
  description    String?
  permissionKeys String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Links employees to products as team members (many-to-many join).
model ProductTeamMember {
  id           String   @id @default(uuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleInProduct String?
  createdAt    DateTime @default(now())

  @@unique([productId, employeeId])
  @@index([productId])
  @@index([employeeId])
}

// ─── Industries & Solutions (Phase 5 admin CRUD; replaces static home config) ───
model Industry {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}

model Solution {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}
